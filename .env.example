# Copia este archivo a .env y completa los valores
# cp .env.example .env

# ── Seguridad ────────────────────────────────────────────
# Los usuarios se crean desde la app en el primer arranque.
# No se necesita configurar credenciales aquí.

# Orígenes permitidos para CORS (separa con coma, sin espacios)
ALLOWED_ORIGINS=http://localhost:8080,https://flujo.tudominio.com

# ── Base de datos ─────────────────────────────────────────
DB_PATH=/app/data/flujo.db

# ── Setup token (opcional) ────────────────────────────────
# Si se define, el token de primera configuración es siempre este valor.
# Útil en dev para que no cambie en cada reinicio. En producción omitir
# (se genera aleatoriamente) o usar un valor largo y seguro.
# SETUP_TOKEN=
