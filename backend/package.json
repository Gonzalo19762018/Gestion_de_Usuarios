{
  "name": "flujo-backend",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "start":      "node src/server.js",
    "dev":        "node --watch src/server.js",
    "test":       "DB_PATH=:memory: node --test tests/",
    "lint":       "eslint src/",
    "lint:fix":   "eslint src/ --fix",
    "format":     "prettier --write src/ tests/"
  },
  "dependencies": {
    "express":           "^5.0.0",
    "better-sqlite3":    "^11.0.0",
    "cors":              "^2.8.5",
    "helmet":            "^8.0.0",
    "compression":       "^1.7.4",
    "express-rate-limit":"^7.2.0"
  },
  "devDependencies": {
    "@eslint/js":           "^9.0.0",
    "eslint":               "^9.0.0",
    "eslint-config-prettier":"^9.0.0",
    "prettier":             "^3.0.0"
  }
}
